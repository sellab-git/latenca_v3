# Latenca — environment variables (copy to .env.local; never commit real values)

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# App queries use the transaction pooler (port 6543); migrations use the direct URL (5432).
DATABASE_URL=            # pooled, e.g. ...pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=              # direct, e.g. ...supabase.com:5432/postgres  (migrations only)

# --- Stripe (Phase 1 checkout) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Gelato (POD) ---
GELATO_API_KEY=
GELATO_SANDBOX=true
GELATO_WEBHOOK_SECRET=

# --- Ops ---
CRON_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
